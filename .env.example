# ============================================
# 论文生成系统 - 环境变量配置
# 复制此文件为 .env 并修改密码
#   cp .env.example .env
# ============================================

# PostgreSQL 密码（请改为强密码）
DB_PASSWORD=123456

# JWT 密钥（请改为随机字符串，至少 32 字符）
JWT_SECRET=YourJwtSecretKeyForThesisGenerator2026PleaseChangeThisInProduction

# 应用端口（一般保持默认）
# SPRING_SERVER_PORT=8080

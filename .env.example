# ============================================
# 论文生成系统 - 环境变量配置说明
# ============================================
# 使用方法：
#   1. 复制此文件为 .env（不会被 git 提交）
#   2. 修改下方变量为你自己的值
#   3. 未设置的变量将使用 application.properties 中的默认值
#
# 团队共享配置（默认值已在 application.properties 中，不需要改）
# ============================================

# ---- 数据库 ----
DB_URL=jdbc:postgresql://localhost:5432/thesis_generator
DB_USERNAME=postgres
DB_PASSWORD=thesis2026

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- 服务器 ----
SERVER_PORT=8080

# ---- JWT ----
JWT_SECRET=YourJwtSecretKeyForThesisGenerator2026PleaseChangeThisInProduction
JWT_EXPIRATION=86400000

# ---- 前端 (Vite) ----
VITE_API_TARGET=http://localhost:8080
